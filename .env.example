NODE_ENV=development

# --- API ---
PORT=4000
CLIENT_ORIGIN=http://localhost:3000,http://localhost:5173

# Mongo
MONGO_URI=mongodb://localhost:27017/ecom_dev

# Redis
REDIS_URL=redis://localhost:6379

# Auth
JWT_ACCESS_SECRET=replace_with_random_64_char_string
JWT_ACCESS_TTL=15m
JWT_REFRESH_SECRET=replace_with_random_64_char_string
JWT_REFRESH_TTL=30d
COOKIE_DOMAIN=localhost

# Razorpay (use test keys in dev)
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=xxxxxxxxxxxxxxxxxxxxxxxx
RAZORPAY_WEBHOOK_SECRET=xxxxxxxxxxxxxxxxxxxxxxxx

# Cloudinary
CLOUDINARY_CLOUD=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Email (Resend)
RESEND_API_KEY=

# SMS (MSG91)
MSG91_AUTH_KEY=
MSG91_SENDER_ID=

# Observability
SENTRY_DSN=
LOG_LEVEL=info

# --- Web (storefront, Next.js) ---
NEXT_PUBLIC_API_URL=http://localhost:4000/api/v1
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxxxxx
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# --- Admin (Vite) ---
VITE_API_URL=http://localhost:4000/api/v1
