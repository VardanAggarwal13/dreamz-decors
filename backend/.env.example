# Server
PORT=5000
NODE_ENV=development
CLIENT_URL=http://localhost:5173

# MongoDB
MONGODB_URI=mongodb://127.0.0.1:27017/dreamzdecors

# Better Auth (authentication)
BETTER_AUTH_URL=http://localhost:5000
BETTER_AUTH_SECRET=replace-me-with-a-long-random-string

# Google OAuth (for "Continue with Google")
# Redirect URI in Google Console: http://localhost:5000/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Cloudinary (paste the keys you'll share with me)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Razorpay
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# Email (SMTP). Leave blank to disable email (e.g. Gmail with an App Password).
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
# The ONE key that controls the sender for ALL app emails (reset, welcome, etc.).
# For Gmail SMTP this should match SMTP_USER.
MAIL_FROM=

# Web-push (VAPID). Generate with:  npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:support@dreamzdecor.com
